{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/agents/stream.js": {
      "maxDuration": 60
    },
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/app",
      "destination": "/index.html"
    },
    {
      "source": "/app/(.*)",
      "destination": "/index.html"
    }
  ]
}
